---
interface Props {
  sectionId: string;
  bg?: "white" | "muted" | "dark";
}

const { sectionId, bg = "white" } = Astro.props;
---

<section id={sectionId} class={`section bg-${bg}`}>
  <div class="inner">
    <slot />
  </div>
</section>

<style>
  .section {
    width: 100%;
    padding: 5rem 0;
  }
  .bg-white {
    background: var(--bgSection);
  }
  .bg-muted {
    background-color: var(--surfaceMuted);
    background-image: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 20 20' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ecd4a3' fill-opacity='0.4' fill-rule='evenodd'%3E%3Ccircle cx='3' cy='3' r='3'/%3E%3Ccircle cx='13' cy='13' r='3'/%3E%3C/g%3E%3C/svg%3E");
  }
  .bg-dark {
    background: var(--bgDark);
    color: var(--textOnDark);
  }

  .inner {
    width: var(--contentWidth);
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .section {
      padding: 3.5rem 0;
    }
  }
</style>
